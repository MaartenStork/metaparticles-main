# mpirun -np 4 lmp_radial -i plane_MP.lmp -v ktilt 12.0 -v ksplay 1.0 -v rcut 2.5 -v wc 2.0 -v zeta 5.0

variable v_rcut string ${rcut}
variable v_splay string ${ksplay}
variable v_tilt string ${ktilt}
variable v_wc string ${wc}
variable v_zeta string ${zeta}
variable t_dump equal 1000


units      lj
atom_style hybrid sphere dipole molecular
dimension   3 
boundary   p p p
# processors   * * 1               # set the number of MPI processors in Lz direction to 1

read_data ../structures/planar_d_0.90_N_2125.lammps_60.data


variable my_diameter equal 4.0
set      type 1 diameter ${my_diameter}
variable my_volume equal (4.0/3.0)*PI*((${my_diameter}*0.5)^3)
# in principle i want to keep my mass fixed for unit conversions! density I dont really care
variable my_mass equal 1.0
variable my_density equal ${my_mass}/${my_volume}

set      type 1 density ${my_density}
print "m:${my_mass} V:${my_volume} rho:${my_density}" file info_mass.dat screen yes
mass 1 ${my_mass}
mass 2 ${my_mass}
reset_timestep 0
group mem_group type 1
group MP_group type 2


variable    kinetic_energy     equal    ke
variable    potential_energy   equal    pe
variable    total_energy       equal    etotal
#************************************
# Box size calculation
#************************************
variable xwidth equal xhi-xlo
variable ywidth equal yhi-ylo
variable zwidth equal zhi-zlo
#********************************************************************************
# thermodynamic parameters
#********************************************************************************
# Target pressure
variable my_press equal -0.0


#********************************************************************************
# pair style
#********************************************************************************
pair_style hybrid membrane_sillanov2 ${v_rcut} lj/cut 1.12
# i j eps sigma ktilt ksplay rcut wc zeta C0
pair_coeff 1 1 membrane_sillanov2 1.0 1.0 ${v_tilt} ${v_splay} ${v_rcut} ${v_wc} ${v_zeta} 0.0
# i j eps sigma rcut
pair_coeff 1 2 lj/cut 0.0 1.75 4.75
pair_coeff 2 2 lj/cut 1.0 2.5 2.5   # sigma from Massimiliano
pair_modify shift yes

bond_style	fene
bond_coeff 1 30 1.8 1 1
special_bonds fene


velocity MP_group set 0 0 0.0


compute        C_temp_baro all temp
compute        C_press_baro all pressure C_temp_baro

write_data test.data

thermo ${t_dump}
thermo_style custom step temp cpuremain pe ebond epair vol
dump coords all custom ${t_dump} position.lammpstrj id type xu yu zu ix iy iz mux muy muz mol fx fy fz

minimize 1.0e-4 1.0e-6 100 1000

fix fNVE_membrane all  nve/sphere update dipole
fix fLANG_standard all langevin 0.2 0.2 1.0 123 zero yes omega yes # higher damp times higher diffusion
timestep   0.001
run 1000

timestep   0.01
run 5000


unfix fNVE_membrane
unfix fLANG_standard

#********************************************************************************
# Production run
#********************************************************************************

fix fNVE_MP MP_group  nve
fix fLANG_standard MP_group langevin 0.25 0.25 1.0 123 zero yes # higher damp times higher diffusion
fix fLANG_standard mem_group langevin 0.25 0.25 1.0 123 zero yes omega yes # higher damp times higher diffusion
fix      fNPH_membrane mem_group    nph/sphere x 0.0 0.0 100.0  y 0.0 0.0 100.0 couple xy drag 5.0 dilate mem_group nreset 100 update dipole
fix_modify fNPH_membrane temp C_temp_baro press C_press_baro


run    500000

